# Copy this file to .env and fill in your own key. NEVER commit the real .env file.

# Required to run the agents with real Gemini calls (get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: set to 1 if using Vertex AI instead of the Gemini Developer API
GOOGLE_GENAI_USE_VERTEXAI=0

# Optional: path to your trained MobileNetV2+CBAM weights file.
# If unset or the file doesn't exist, the classifier runs in DEMO mode.
TOMATO_MODEL_WEIGHTS=model/weights/mobilenetv2_cbam_tomato.keras
